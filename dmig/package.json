{
  "name": "dmig",
  "version": "0.2.0-poc",
  "description": "Docker Desktop Migration Tool",
  "main": "out/main/index.js",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "build:win": "npm run build && electron-builder --win",
    "build:linux": "npm run build && electron-builder --linux",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run"
  },
  "dependencies": {
    "check-disk-space": "^3.4.0",
    "dockerode": "^4.0.2",
    "i18next": "^23.11.0",
    "jszip": "^3.10.1",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-i18next": "^14.1.0",
    "simple-zstd": "^2.0.0",
    "tar-stream": "^3.2.0",
    "write-file-atomic": "^7.0.1",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/write-file-atomic": "^4.0.3",
    "@eslint/js": "^9.10.0",
    "@types/dockerode": "^3.3.29",
    "@types/node": "^22.13.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/tar-stream": "^3.1.4",
    "@vitejs/plugin-react": "^4.2.0",
    "electron": "^39.0.0",
    "electron-builder": "^24.13.0",
    "electron-vite": "^2.1.0",
    "eslint": "^9.10.0",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "globals": "^15.9.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.5.0",
    "vite": "^5.2.0",
    "vitest": "^3.0.0"
  },
  "build": {
    "appId": "com.dmig.app",
    "productName": "dmig",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*"
    ]
  }
}
