## 2. state file

長時間処理の進捗を **永続化** し、resume を可能にする:

### 2.1 state file 構造

```python
# src/my_tool/state.py
from __future__ import annotations
import json
import hashlib
from datetime import datetime, timezone
from pathlib import Path
from typing import Any
from pydantic import BaseModel

class State(BaseModel):
    """state file のスキーマ。"""
    tool_name: str
    tool_version: str
    started_at: str  # ISO 8601 UTC
    updated_at: str
    input_hash: str  # 入力データの hash
    phase: str       # "init" | "phase1" | "phase2" | "completed" | "failed"
    completed_items: list[str]
    failed_items: list[str]
    metadata: dict[str, Any] = {}

class StateFile:
    def __init__(self, path: Path) -> None:
        self.path = path
        self.state = self._load_or_create()

    def _load_or_create(self) -> State:
        if self.path.exists():
            return State.model_validate_json(self.path.read_text(encoding="utf-8"))
        return State(
            tool_name="my-tool",
            tool_version="0.1.0",
            started_at=datetime.now(timezone.utc).isoformat(),
            updated_at=datetime.now(timezone.utc).isoformat(),
            input_hash="",
            phase="init",
            completed_items=[],
            failed_items=[],
        )

    def save(self) -> None:
        """atomic に state を書き込む。"""
        self.state.updated_at = datetime.now(timezone.utc).isoformat()
        tmp = self.path.with_suffix(".tmp")
        tmp.write_text(self.state.model_dump_json(indent=2), encoding="utf-8")
        tmp.replace(self.path)

    def mark_completed(self, item: str) -> None:
        if item not in self.state.completed_items:
            self.state.completed_items.append(item)
        self.save()

    def mark_failed(self, item: str) -> None:
        if item not in self.state.failed_items:
            self.state.failed_items.append(item)
        self.save()

    def update_phase(self, phase: str) -> None:
        self.state.phase = phase
        self.save()
```

### 2.2 配置場所
- 出力先と **同じディレクトリ** に配置（同一 FS で atomic）
- 命名: `<tool>.state.json` または `<output>.state.json`

