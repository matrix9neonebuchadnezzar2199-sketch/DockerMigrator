## 3. checkpoint / resume

### 3.1 フェーズ単位の checkpoint

```python
def migrate(state: StateFile, items: list[Item]) -> None:
    if state.state.phase == "init":
        state.update_phase("phase1_prepare")
        prepare()
        state.update_phase("phase2_export")
    
    if state.state.phase in ("phase2_export", "init"):
        for item in items:
            if item.id in state.state.completed_items:
                logger.debug(f"Skipping already completed: {item.id}")
                continue
            try:
                export(item)
                state.mark_completed(item.id)
            except Exception as e:
                state.mark_failed(item.id)
                raise
        state.update_phase("phase3_verify")
    
    if state.state.phase == "phase3_verify":
        verify_all()
        state.update_phase("completed")
```

### 3.2 resume サブコマンド

```python
@cli.command()
@click.argument("state_file", type=click.Path(exists=True, path_type=Path))
def resume(state_file: Path) -> None:
    """state ファイルから処理を再開する。"""
    state = StateFile(state_file)
    
    if state.state.phase == "completed":
        click.echo("Already completed.")
        return
    
    # 入力ハッシュチェック（後述）
    current_hash = calculate_input_hash(...)
    if state.state.input_hash != current_hash:
        raise ValidationError(
            f"Input changed since last run. "
            f"Expected hash {state.state.input_hash}, got {current_hash}. "
            f"Use --force to override."
        )
    
    # フェーズから再開
    items = load_items(...)
    migrate(state, items)
```

