## 8. 設定ファイル探索順（実装例）

```python
def find_config_file(explicit: Path | None = None) -> Path | None:
    """設定ファイルを優先順位で探す。"""
    if explicit:
        if not explicit.exists():
            raise ConfigError(f"指定された設定ファイルが見つかりません: {explicit}")
        return explicit
    
    candidates = [
        Path.cwd() / "config.toml",
        Path.cwd() / f".{__package__}.toml",
        Path.home() / ".config" / __package__ / "config.toml",
    ]
    
    if sys.platform != "win32":
        candidates.append(Path("/etc") / __package__ / "config.toml")
    
    for path in candidates:
        if path.exists():
            return path
    return None  # 設定ファイルなしでもデフォルトで動作
```

