## 4. ロガー設定（rich.logging 統合）

`logging.config.dictConfig` で集中設定。`rich.logging.RichHandler` で美しい表示:

```python
# src/my_tool/_logging.py
import logging
import logging.config
from pathlib import Path
from rich.logging import RichHandler

def setup_logging(
    verbose: int = 0,
    quiet: bool = False,
    log_file: Path | None = None,
    no_color: bool = False,
) -> None:
    if quiet:
        level = logging.WARNING
    elif verbose == 0:
        level = logging.WARNING
    elif verbose == 1:
        level = logging.INFO
    elif verbose == 2:
        level = logging.DEBUG
    else:
        level = logging.DEBUG  # -vvv 以上は外部ライブラリも DEBUG

    handlers: dict[str, dict] = {
        "console": {
            "class": "rich.logging.RichHandler",
            "level": level,
            "rich_tracebacks": True,
            "tracebacks_show_locals": verbose >= 2,
            "show_time": True,
            "show_path": verbose >= 1,
            "markup": True,
        },
    }

    if log_file:
        handlers["file"] = {
            "class": "logging.handlers.RotatingFileHandler",
            "filename": str(log_file),
            "maxBytes": 10 * 1024 * 1024,  # 10 MB
            "backupCount": 5,
            "encoding": "utf-8",
            "level": logging.DEBUG,  # ファイルには常に DEBUG 全部
            "formatter": "detail",
        }

    config: dict = {
        "version": 1,
        "disable_existing_loggers": False,
        "formatters": {
            "detail": {
                "format": "%(asctime)s [%(levelname)-8s] %(name)s:%(lineno)d - %(message)s",
                "datefmt": "%Y-%m-%d %H:%M:%S",
            },
        },
        "handlers": handlers,
        "root": {
            "level": "DEBUG" if log_file else level,
            "handlers": list(handlers.keys()),
        },
        "loggers": {
            "urllib3": {"level": "WARNING" if verbose < 3 else "DEBUG"},
            "asyncio": {"level": "WARNING"},
        },
    }
    logging.config.dictConfig(config)
```

**ハンドラ多重登録防止**: `setup_logging` は CLI エントリポイントで **1 回だけ呼ぶ**。サブコマンドから複数回呼ばれると hanlder が重複して同じログが複数出力される。

