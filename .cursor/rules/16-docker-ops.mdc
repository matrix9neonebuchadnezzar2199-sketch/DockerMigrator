## 4. volume バックアップ・移送

### 4.1 定型パターン: tar 経由

**エクスポート**:
```bash
docker run --rm \
  -v <volume-name>:/data:ro \
  -v "$(pwd)":/backup \
  alpine \
  tar -czf /backup/<volume-name>.tar.gz -C /data .
```

**インポート**:
```bash
docker volume create <volume-name>
docker run --rm \
  -v <volume-name>:/data \
  -v "$(pwd)":/backup \
  alpine \
  tar -xzf /backup/<volume-name>.tar.gz -C /data
```

### 4.2 Python ラッパー例（移行ツールのコア）

```python
import subprocess
from pathlib import Path
from .exceptions import ExternalCommandError

def export_volume(volume: str, output: Path, *, dry_run: bool = False) -> None:
    """volume を tar.gz にエクスポート。"""
    cmd = [
        "docker", "run", "--rm",
        "-v", f"{volume}:/data:ro",
        "-v", f"{output.parent.resolve()}:/backup",
        "alpine",
        "tar", "-czf", f"/backup/{output.name}", "-C", "/data", ".",
    ]
    if dry_run:
        logger.info(f"[DRY-RUN] {' '.join(cmd)}")
        return
    result = subprocess.run(cmd, capture_output=True, text=True, timeout=3600)
    if result.returncode != 0:
        raise ExternalCommandError(cmd, result.returncode, result.stderr)

def import_volume(volume: str, archive: Path, *, dry_run: bool = False) -> None:
    """tar.gz から volume を復元。volume は新規作成。"""
    if not dry_run:
        subprocess.run(["docker", "volume", "create", volume], check=True)
    cmd = [
        "docker", "run", "--rm",
        "-v", f"{volume}:/data",
        "-v", f"{archive.parent.resolve()}:/backup",
        "alpine",
        "tar", "-xzf", f"/backup/{archive.name}", "-C", "/data",
    ]
    if dry_run:
        logger.info(f"[DRY-RUN] {' '.join(cmd)}")
        return
    result = subprocess.run(cmd, capture_output=True, text=True, timeout=3600)
    if result.returncode != 0:
        raise ExternalCommandError(cmd, result.returncode, result.stderr)
```

